continue_work = True

while continue_work:
    # 1. المدخلات (الفصل 5: أساسيات البرمجة بلغة بايثون)
    print("\n--- مساعد مريض السكري الذكي ---")
    name = input("ادخل الاسم : ")
    age = input("ادخل العمر : ")
    sex = input("ادخل النوع (ذكر / أنثى) : ")
    weight = input("ادخل الوزن بالكيلو : ")
    height = input("ادخل الطول بالسنتيمتر : ")
    activity = input("ما هو مستوى نشاطك؟ (1: خامل، 2: نشاط خفيف، 3: نشاط متوسط، 4: نشاط عالي) : ")
    
    # 2. التحويل (الفصل 5: تحويل أنواع البيانات)
    # نحول المدخلات من نصوص إلى أرقام لكي نتمكن من الحساب
    weight_num = float(weight)
    height_num = float(height)
    age_num = int(age)

    # 3. حساب الـ BMR الأساسي (الفصل 6: المنطق الشرطي)
    # المعادلة الطبية تختلف بناءً على الجنس (ذكر/أنثى)
    if sex == "ذكر":
        bmr_base = (10 * weight_num) + (6.25 * height_num) - (5 * age_num) + 5
    else:
        bmr_base = (10 * weight_num) + (6.25 * height_num) - (5 * age_num) - 161

    # 4. حساب إجمالي السعرات بناءً على النشاط (الفصل 6: الجمل الشرطية المتعددة elif)
    if activity == "1":
        total_calories = bmr_base * 1.2
        activity_status = "جسمك خامل! تحتاج لنشاط كثير"
    elif activity == "2":
        total_calories = bmr_base * 1.375
        activity_status = "جسمك غير نشط! تحتاج لنشاط أكثر"
    elif activity == "3":
        total_calories = bmr_base * 1.55
        activity_status = "نشاط متوسط! ابذل المزيد"
    else:
        total_calories = bmr_base * 1.725
        activity_status = "نشاط عالي! استمر"

    # 5. حساب الكربوهيدرات لمرضى السكري (المنطق الحسابي - الفصل 5)
    # الاحتياج اليومي الكلي من الكربوهيدرات (45% من السعرات)
    # كل جرام كربوهيدرات يحتوي على 4 سعرات حرارية
    carbo_needed = (total_calories * 0.45) / 4
    # الاحتياج في الوجبة الواحدة (تقسيم على 3 وجبات رئيسية)
    carbo_per_meal = carbo_needed / 3

    # 6. التفاعل مع الوجبة الحالية
    print("\n--- تقرير احتياجاتك اليومية ---")
    print(activity_status)
    print("إجمالي السعرات التي تحتاجها يومياً:", round(total_calories), "سعر حراري")
    print("احتياجك اليومي الكلي من الكربوهيدرات:", round(carbo_needed), "جرام")
    print("المسموح لك في الوجبة الواحدة:", round(carbo_per_meal), "جرام")
    print("---------------------------------")

    # 7. طلب كمية الكربوهيدرات التي أكلها المستخدم فعلياً في وجبة واحدة
    carbo_eaten = float(input("ما كمية الكربوهيدرات التي أكلتها في وجبتك الحالية (بالجرام)؟ "))

    # 8. التنبيه (زائد - ناقص) - (الفصل 6: التحكم في سير البرنامج)
    if carbo_eaten > carbo_per_meal + 5:
        print("⚠️ تنبيه: هذه الوجبة تحتوي على كربوهيدرات زائدة عن المسموح لك!")
        print("الزيادة هي:", round(carbo_eaten - carbo_per_meal), "جرام")
    elif carbo_eaten < carbo_per_meal - 5:
        print("ℹ️ ملحوظة: وجبتك تحتوي على كربوهيدرات أقل من احتياجك.")
        print("النقص هو:", round(carbo_per_meal - carbo_eaten), "جرام")
    else:
        print("✅ أحسنت! وجبتك متوازنة وضمن نطاق الأمان الصحي.")

    # 9. سؤال التكرار (الفصل 6: حلقات التكرار while)
    print("\n---------------------------------")
    answer = input("هل تريد حساب سعرات شخص آخر؟ (نعم / لا): ")
    if answer != "نعم":
        continue_work = False

print("\nتم إنهاء البرنامج. تمنياتنا لكم بدوام الصحة والعافية!")
